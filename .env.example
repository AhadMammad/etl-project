# Per-user overrides: copy to .env.local and edit, or run: make init-user
# Do not commit .env.local to version control.

COMPOSE_PROJECT_NAME=etl

# Ports — change if defaults clash with other local services
MYSQL_PORT=3306
NIFI_PORT=8080
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=etl_db
MYSQL_USER=etl_user
MYSQL_PASSWORD=etl_pass

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=etl-data
